{
  "name": "thiefbook-desktop",
  "version": "1.0.2",
  "description": "摸鱼看书 · Win11 桌面隐蔽阅读器（Electron）",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win portable"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.bluemount.thiefbook",
    "productName": "thiefbook",
    "files": ["main.js", "preload.js", "renderer/**/*"],
    "win": {
      "target": "portable"
    },
    "portable": {
      "artifactName": "thiefbook-desktop-${version}.exe"
    }
  }
}
